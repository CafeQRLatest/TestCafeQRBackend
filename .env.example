SPRING_PROFILES_ACTIVE=prod

# Supabase Postgres: use Session Pooler or Direct with IPv4 support, not Transaction Pooler.
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.project-ref
SPRING_DATASOURCE_PASSWORD=replace-with-supabase-password

# Upstash Redis.
SPRING_DATA_REDIS_HOST=replace-with-upstash-host
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=replace-with-upstash-password
SPRING_DATA_REDIS_SSL=true

# CloudAMQP RabbitMQ.
SPRING_RABBITMQ_HOST=replace-with-cloudamqp-host
SPRING_RABBITMQ_PORT=5671
SPRING_RABBITMQ_USERNAME=replace-with-cloudamqp-user
SPRING_RABBITMQ_PASSWORD=replace-with-cloudamqp-password
SPRING_RABBITMQ_VHOST=replace-with-cloudamqp-vhost
SPRING_RABBITMQ_SSL=true

# Frontend URLs.
ALLOWED_ORIGINS=https://replace-with-vercel-domain.vercel.app
FRONTEND_URL=https://replace-with-vercel-domain.vercel.app

# JWT RSA keys: Base64 PKCS8 private key and X509 public key, without PEM headers.
JWT_PRIVATE_KEY=replace-with-base64-private-key
JWT_PUBLIC_KEY=replace-with-base64-public-key

# Gmail API sender.
EMAIL_PROVIDER=gmail-api
GMAIL_SENDER_EMAIL=cafeqrllp@gmail.com
GMAIL_CLIENT_ID=replace-with-google-oauth-client-id
GMAIL_CLIENT_SECRET=replace-with-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=replace-with-google-oauth-refresh-token
OTP_LOG_CODE=false

# Razorpay.
RAZORPAY_KEY_ID=replace-with-rotated-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-rotated-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

APP_OBSERVABILITY_LOG_ALL_API_REQUESTS=false
