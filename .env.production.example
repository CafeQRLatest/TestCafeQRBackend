# ──────────────────────────────────────────────────────────────
# CafeQR 2.0 — Production Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to Git — it contains secrets!
#
# Usage:
#   cp .env.production.example .env
#   nano .env   # fill in values
# ──────────────────────────────────────────────────────────────

# ── Application ──
SPRING_PROFILES_ACTIVE=prod

# ── Database ──
DB_NAME=pos_db
DB_USER=cafeqr_prod
DB_PASSWORD=CHANGE_ME_use_a_strong_password_here

# ── RabbitMQ ──
RABBITMQ_USER=cafeqr
RABBITMQ_PASSWORD=CHANGE_ME_use_a_strong_password_here

# ── Docker Images (override for manual deployments) ──
# BACKEND_IMAGE=ghcr.io/cafeqrllp/cafeqr-backend:latest
# FRONTEND_IMAGE=ghcr.io/cafeqrllp/cafeqr-frontend:latest

# ── JWT RSA Keys ──
# Base64-encoded PKCS8 private key and X509 public key (no PEM headers).
JWT_PRIVATE_KEY=PASTE_YOUR_BASE64_PRIVATE_KEY_HERE
JWT_PUBLIC_KEY=PASTE_YOUR_BASE64_PUBLIC_KEY_HERE

# ── Frontend URLs ──
ALLOWED_ORIGINS=https://YOUR_DOMAIN
FRONTEND_URL=https://YOUR_DOMAIN

# ── Email (Gmail API) ──
EMAIL_PROVIDER=gmail-api
GMAIL_SENDER_EMAIL=cafeqrllp@gmail.com
GMAIL_CLIENT_ID=PASTE_YOUR_GOOGLE_OAUTH_CLIENT_ID
GMAIL_CLIENT_SECRET=PASTE_YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GMAIL_REFRESH_TOKEN=PASTE_YOUR_GOOGLE_OAUTH_REFRESH_TOKEN
OTP_LOG_CODE=false

# ── Razorpay ──
RAZORPAY_KEY_ID=PASTE_YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=PASTE_YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=PASTE_YOUR_RAZORPAY_WEBHOOK_SECRET

# ── Backup ──
CAFEQR_BACKUP_STORAGE_DIR=/app/data/backups
CAFEQR_BACKUP_RESTORE_TOKEN_MINUTES=30

# ── Observability ──
APP_OBSERVABILITY_LOG_ALL_API_REQUESTS=false
