# CafeQR 2.0 - Frontend runtime environment for docker-compose.prod.yml
# Copy this file to .env.frontend on the VPS and fill in the values.
# Do not commit .env.frontend.

# IP-first deployment. Replace YOUR_VPS_IP with the Hostinger VPS IP.
# After DNS is ready, switch these to https://YOUR_DOMAIN.
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP
NEXT_PUBLIC_AI_PARSE_URL=http://YOUR_VPS_IP/api/ai/parse-menu

# Server-side Next.js API route credentials for /api/ai/parse-menu.
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY
# or use multiple keys:
# GEMINI_API_KEYS=key1,key2
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash
GEMINI_QUOTA_COOLDOWN_MS=43200000
GEMINI_AUTH_COOLDOWN_MS=3600000
